# Per-VM config. Written by install.sh from the repo you run it in. NOT committed.
# Declares which repo lives on THIS vm.
#
# REPO_DIR   path to the repo checkout on this VM
# REPO_SLUG  owner/repo on GitHub
#
# Example:
# REPO_DIR="$HOME/todo-factory-demo"
# REPO_SLUG="petealbertson/todo-factory-demo"
