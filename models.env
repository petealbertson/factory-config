# Skill -> model bindings. Edit these lines to swap models. Reloads every run.
# Available providers on this VM (pi --list-models): zai, deepseek, kimi-coding, opencode-go, mistral
#
# Strong + large context: zai/glm-5.2   Cheaper: zai/glm-4.5-air   deepseek/deepseek-v4-flash

IMPLEMENT_MODEL="zai/glm-5.2"
FIX_MODEL="zai/glm-5.2"

# --- multi-perspective review ---
# REVIEW_MODEL runs the trivial-tier single pass AND coordinates the fan-out
# (judge). Specialists are distributed across providers so no single quota
# exhaustion can sink a review pass. Tune freely; these are starting defaults.
REVIEW_MODEL="zai/glm-5.2"
REVIEW_SECURITY_MODEL="zai/glm-5.2"
REVIEW_QUALITY_MODEL="deepseek/deepseek-v4-pro"
REVIEW_PERFORMANCE_MODEL="zai/glm-5.1"
REVIEW_DOCS_MODEL="zai/glm-4.5-air"
