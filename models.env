# Skill -> model bindings. Edit these lines to swap models. Reloads every run.
# Available providers on this VM (pi --list-models): umans, zai, deepseek, kimi-coding
#
# All roles on umans (single provider):
#   umans/umans-coder      = Kimi K2.7 Code, always-on reasoning, 256K  (implement/fix)
#   umans/umans-glm-5.2    = large ctx 406K/128K, reasoning             (review + coordinator + specialists)
#   umans/umans-flash      = fast/cheap                                  (docs)

IMPLEMENT_MODEL="umans/umans-coder"
FIX_MODEL="umans/umans-coder"

# --- multi-perspective review ---
# REVIEW_MODEL runs the trivial-tier single pass AND coordinates the fan-out
# (judge, line 319 in run.sh). All roles intentionally on one provider (umans);
# note the tradeoff: a single umans outage stalls all review roles.
REVIEW_MODEL="umans/umans-glm-5.2"
REVIEW_SECURITY_MODEL="umans/umans-glm-5.2"
REVIEW_QUALITY_MODEL="umans/umans-glm-5.2"
REVIEW_PERFORMANCE_MODEL="umans/umans-glm-5.2"
REVIEW_DOCS_MODEL="umans/umans-flash"
